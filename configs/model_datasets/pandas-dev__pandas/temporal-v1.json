{
  "config_schema_version": "1",
  "repository": "pandas-dev/pandas",
  "split_strategy": "temporal_calendar",
  "validation_start": "2026-02-01T00:00:00Z",
  "test_start": "2026-04-01T00:00:00Z",
  "boundary_semantics": {
    "train": "created_at < validation_start",
    "validation": "validation_start <= created_at < test_start",
    "test": "created_at >= test_start"
  },
  "minimum_positive_support": {
    "train": 1,
    "validation": 1,
    "test": 1
  },
  "low_support_warning_threshold": 5
}
